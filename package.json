{
  "name": "moten",
  "version": "1.0.0",
  "main": "index.js",
  "packageManager": "pnpm@7.9.5",
  "engines": {
    "npm": ">=8.1.0",
    "node": ">=18"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "in": "pnpm i -r",
    "ui": "pnpm -F @moten/ui dev",
    "ui:build": "pnpm -F @moten/ui build",
    "clear": "rimraf --glob ./node_modules ./packages/**/node_modules ./packages/**/dist",
    "play:vue3": "pnpm -F @moten/ui build && pnpm -F @moten/playground-vue3 dev",
    "play:vue2": "pnpm -F @moten/ui build && pnpm -F @moten/playground-vue2 serve",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "pnpm -F @moten/admin lint"
  },
  "config": {
    "commitizen": {
      "path": "cz-vinyl"
    }
  },
  "pnpm": {
    "packageExtensions": {
      "vue-template-compiler": {
        "devDependencies": {
          "vue": "~2.7.16"
        }
      },
      "vue-template-compiler@2.7.16": {
        "devDependencies": {
          "vue": "~2.7.16"
        }
      }
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "commitizen": "^4.3.0",
    "cz-vinyl": "^2.5.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "rimraf": "^5.0.7"
  }
}
